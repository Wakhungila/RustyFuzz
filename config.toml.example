chain = "evm"
rpc_url = "https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY"   # or any good RPC
fork_block = 22000000  
target_contract = "0x0000000000000000000000000000000000001337"   # Contract Address
fuzzer_address = "0x0000000000000000000000000000000000001337"    # Fuzzing Address or your wallet address
max_depth = 5
initial_seeds = 50
timeout_secs = 60
corpus_dir = "corpus"
report_dir = "reports"
mainnet_seed_bundle = "target-mainnet"
llm_enabled = false

[hardened_defi]
enabled = false
historical_seed_file = "seeds/example_historical_seed.json"
max_template_sequences = 128
enable_actor_model = true
enable_economic_delta = true
enable_protocol_invariants = true
enable_exploit_templates = true
min_persist_confidence = 0.70
